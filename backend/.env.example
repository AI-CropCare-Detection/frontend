PORT=3001
# Backend terminal logging: error | warn | info | debug (debug = most verbose)
LOG_LEVEL=info

# OpenRouter API Configuration (using OpenAI models via OpenRouter)
# Get your API key at https://openrouter.ai/keys
OPEN_ROUTER_API_KEY=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
# Model name (OpenRouter supports OpenAI models like gpt-4o, gpt-4o-mini, etc.)
OPENAI_MODEL=gpt-4o
# Optional: URL of your trained crop analysis model (POST image body, expect JSON: timeTaken, accuracyRate, recoveryRate, optional recommendations, insights, cropType/leafType)
# CROP_MODEL_URL=https://your-model-endpoint/analyze

# Firebase Admin SDK (for account deletion)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# Frontend URL (for generating deletion links)
FRONTEND_URL=http://localhost:5173

# Email Configuration (for account deletion emails)
# Option 1: Use SMTP (Gmail, Firebase SMTP, or custom SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Option 2: Use SendGrid (alternative to SMTP)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Email sender identity
EMAIL_FROM=noreply@aicropcare.com
EMAIL_FROM_NAME=AI-Powered CropCare
